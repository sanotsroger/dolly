#!/usr/bin/env bash
# dolly - sincroniza diretórios locais com rclone (exclusões; deleção espelhada opcional via --mirror)
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dolly"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/dolly"
PATHS_FILE="$CONFIG_DIR/paths.conf"
FILTERS_FILE="$CONFIG_DIR/filters.txt"
LOGS_DIR="$DATA_DIR/logs"

SCRIPT_NAME="dolly"

# ---------- cores (desativadas se a saída não for um terminal) ----------
if [ -t 1 ]; then
  C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
  C_RED=$'\033[31m'; C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'; C_CYAN=$'\033[36m'
else
  C_RESET=''; C_BOLD=''; C_DIM=''
  C_RED=''; C_GREEN=''; C_YELLOW=''
  C_BLUE=''; C_CYAN=''
fi

info()    { printf '%s\n' "${C_BLUE}➜${C_RESET} $*"; }
ok()      { printf '%s\n' "${C_GREEN}✔${C_RESET} $*"; }
warn()    { printf '%s\n' "${C_YELLOW}⚠${C_RESET} $*"; }
err()     { printf '%s\n' "${C_RED}✖${C_RESET} $*" >&2; }

# ---------- painéis com bordas unicode (inspirado em btop/gh-dash) ----------
BOX_WIDTH="$(tput cols 2>/dev/null || echo 80)"
[ -z "$BOX_WIDTH" ] && BOX_WIDTH=80
[ "$BOX_WIDTH" -lt 44 ] && BOX_WIDTH=44
MAX_CHANGE_LINES=12

box_top() {
  local title="$1" color="${2:-$C_CYAN}" n
  n=$(( BOX_WIDTH - 5 - ${#title} ))
  [ "$n" -lt 1 ] && n=1
  printf '%s╭─ %s%s%s ' "$color" "$C_RESET$C_BOLD" "$title" "$C_RESET$color"
  printf -- '─%.0s' $(seq 1 "$n")
  printf '╮%s\n' "$C_RESET"
}

box_bottom() {
  local color="${1:-$C_CYAN}"
  printf '%s╰' "$color"
  printf -- '─%.0s' $(seq 1 $((BOX_WIDTH - 2)))
  printf '╯%s\n' "$C_RESET"
}

box_divider() {
  printf '%s├' "$C_CYAN"
  printf -- '─%.0s' $(seq 1 $((BOX_WIDTH - 2)))
  printf '┤%s\n' "$C_RESET"
}

# $1 texto puro (usado para medir/truncar), $2 texto com cores para exibir (opcional), $3 cor da borda (opcional)
box_line() {
  local plain="$1" printed="${2:-$1}" color="${3:-$C_CYAN}" avail pad
  avail=$((BOX_WIDTH - 4))
  if [ "${#plain}" -gt "$avail" ]; then
    plain="${plain:0:avail-1}…"
    printed="$plain"
  fi
  pad=$((avail - ${#plain}))
  printf '%s│%s %s%*s %s│%s\n' "$color" "$C_RESET" "$printed" "$pad" "" "$color" "$C_RESET"
}

# painel vermelho para erros fatais: um ou mais argumentos, uma linha cada
err_box() {
  local msg
  {
    box_top "erro" "$C_RED"
    for msg in "$@"; do
      box_line "✖ $msg" "" "$C_RED"
    done
    box_bottom "$C_RED"
  } >&2
}

# barra estilo medidor do btop: label, valor, total, cor, largura reservada pro valor
# a barra ocupa todo o espaço horizontal disponível na caixa, deixando só o
# necessário no final para o número (alinhado à direita e com largura fixa
# entre as três barras, para elas ficarem alinhadas).
meter_bar() {
  local label="$1" value="$2" total="$3" color="$4" value_width="${5:-1}"
  local label_width=11 avail width filled=0 empty bar=""
  avail=$((BOX_WIDTH - 4))
  width=$((avail - label_width - 1 - 1 - value_width))
  [ "$width" -lt 1 ] && width=1
  [ "$total" -gt 0 ] && filled=$(( value * width / total ))
  [ "$filled" -gt "$width" ] && filled=$width
  empty=$((width - filled))
  [ "$filled" -gt 0 ] && bar="$(printf '█%.0s' $(seq 1 "$filled"))"
  [ "$empty" -gt 0 ] && bar="${bar}$(printf '░%.0s' $(seq 1 "$empty"))"
  box_line "$(printf '%-11s %s %*s' "$label" "$bar" "$value_width" "$value")" \
    "$(printf '%-11s %s%s%s %*s' "$label" "$color" "$bar" "$C_RESET" "$value_width" "$value")"
}

usage() {
  cat <<EOF
${C_BOLD}dolly${C_RESET} - sincroniza diretórios locais com rclone (exclusões; deleção espelhada opcional via --mirror)

${C_BOLD}USO${C_RESET}
  dolly init                  Cria os arquivos de configuração e diretórios de log
  dolly --dry-run|-d          Simula a sincronização (nada é copiado/apagado)
  dolly [-y|--yes]            Executa a sincronização de fato (por padrão, nunca apaga no destino)
  dolly --mirror|-m           Ativa deleção espelhada: apaga no destino o que não existe mais na origem
  dolly --edit-path|-ep       Abre paths.conf no editor disponível (nano, vim ou vi)
  dolly --edit-filter|-ef     Abre filters.txt no editor disponível (nano, vim ou vi)
  dolly --log-delete|-lgd [N] Apaga execuções (dry-run e prod) com mais de N dias (padrão: 30)
  dolly --view-log|-vl [--dir N]
                              Escolhe dry-run/prod, escolhe um dos N diretórios de execução
                              mais recentes (padrão: 5) e mostra um dos arquivos de log daquela
                              execução (via bat, ou cat se indisponível)
  dolly -h|--help             Mostra esta ajuda

  Por padrão cada par roda com ${C_BOLD}rclone copy${C_RESET} (só copia/atualiza, nunca apaga).
  Com --mirror/-m, roda ${C_BOLD}rclone sync${C_RESET} (espelha a origem, apagando extras no destino).

  Qualquer outra flag não reconhecida (ex.: --bwlimit 1M, --transfers 8,
  --exclude "*.tmp") é repassada direto para o rclone de cada par.

${C_BOLD}CONFIGURAÇÃO${C_RESET}
  $PATHS_FILE
      Pares "source|destination", um por linha. Linhas em branco e
      iniciadas com # são ignoradas.

  $FILTERS_FILE
      Regras de exclusão no formato --filter-from do rclone.
      Ex.: - .git/**
           - node_modules/**
           - *.tmp

${C_BOLD}LOGS${C_RESET}
  $LOGS_DIR/dry-run/<timestamp>/   logs das simulações
  $LOGS_DIR/prod/<timestamp>/      logs das execuções reais

  Para cada par sincronizado, dois arquivos são gerados:
    <job>.rclone.log    saída técnica detalhada do rclone (-v)
    <job>.changes.log   lista estilo git status (+ adicionado, * modificado, - removido)
                        "- removido" só aparece em execuções com --mirror
  Além de um summary.log com o resumo agregado de todos os pares.

${C_BOLD}EXEMPLOS${C_RESET}
  dolly init
  dolly --dry-run
  dolly -y
  dolly -y --mirror
  dolly --edit-path
  dolly -y --bwlimit 1M --transfers 4
  dolly --log-delete
  dolly -lgd 15
  dolly --view-log
  dolly -vl
  dolly --view-log --dir 10
  dolly -vl --dir 10
EOF
}

require_rclone() {
  if ! command -v rclone >/dev/null 2>&1; then
    err_box "rclone não encontrado no PATH. Instale-o antes de continuar (https://rclone.org/downloads/)."
    exit 1
  fi
}

EDITOR_BIN=""

require_editor() {
  if command -v nano >/dev/null 2>&1; then
    EDITOR_BIN="nano"
  elif command -v vim >/dev/null 2>&1; then
    EDITOR_BIN="vim"
  elif command -v vi >/dev/null 2>&1; then
    EDITOR_BIN="vi"
  else
    err_box "Nenhum editor de texto compatível encontrado no PATH (nano, vim ou vi)." "Instale um deles ou edite o arquivo manualmente."
    exit 1
  fi
}

PAGER_BIN=""
PAGER_ARGS=()

require_pager() {
  if command -v bat >/dev/null 2>&1; then
    PAGER_BIN="bat"
    PAGER_ARGS=(--paging=auto --style=full)
  else
    PAGER_BIN="cat"
    PAGER_ARGS=()
  fi
}

# cria $PATHS_FILE com o template padrão se ainda não existir; devolve 1 se já existia
ensure_paths_file() {
  if [ -f "$PATHS_FILE" ]; then
    return 1
  fi
  cat > "$PATHS_FILE" <<'EOF'
# dolly - pares de sincronização
# Formato: source|destination  (um par por linha)
# Linhas em branco ou iniciadas com # são ignoradas.
/home/sanotsroger/Downloads/dolly/source/dir_app|/home/sanotsroger/Downloads/dolly/destination/src/dir_app
/home/sanotsroger/Downloads/dolly/source/dir_test|/home/sanotsroger/Downloads/dolly/destination/src/other/dir_test
EOF
}

# cria $FILTERS_FILE com o template padrão se ainda não existir; devolve 1 se já existia
ensure_filters_file() {
  if [ -f "$FILTERS_FILE" ]; then
    return 1
  fi
  cat > "$FILTERS_FILE" <<'EOF'
# dolly - regras de exclusão (formato --filter-from do rclone)
# Descomente/adicione linhas "- padrao" para excluir arquivos/diretórios.
# - .git/**
# - node_modules/**
# - *.tmp
# - *.log
# - .DS_Store
EOF
}

cmd_init() {
  mkdir -p "$CONFIG_DIR" "$LOGS_DIR/dry-run" "$LOGS_DIR/prod"

  box_top "dolly · init"
  box_line "✔ Diretórios criados em $CONFIG_DIR e $LOGS_DIR" \
    "$(printf '%s✔%s Diretórios criados em %s e %s' "$C_GREEN" "$C_RESET" "$CONFIG_DIR" "$LOGS_DIR")"

  if ensure_paths_file; then
    box_line "✔ Criado $PATHS_FILE" "$(printf '%s✔%s Criado %s' "$C_GREEN" "$C_RESET" "$PATHS_FILE")"
  else
    box_line "⚠ $PATHS_FILE já existe, mantendo como está" \
      "$(printf '%s⚠%s %s já existe, mantendo como está' "$C_YELLOW" "$C_RESET" "$PATHS_FILE")"
  fi

  if ensure_filters_file; then
    box_line "✔ Criado $FILTERS_FILE" "$(printf '%s✔%s Criado %s' "$C_GREEN" "$C_RESET" "$FILTERS_FILE")"
  else
    box_line "⚠ $FILTERS_FILE já existe, mantendo como está" \
      "$(printf '%s⚠%s %s já existe, mantendo como está' "$C_YELLOW" "$C_RESET" "$FILTERS_FILE")"
  fi

  box_line ""
  box_line "Edite com --edit-path/--edit-filter e depois rode: dolly --dry-run"
  box_bottom
}

cmd_edit_path() {
  mkdir -p "$CONFIG_DIR"
  ensure_paths_file || true
  require_editor
  "$EDITOR_BIN" "$PATHS_FILE"
}

cmd_edit_filter() {
  mkdir -p "$CONFIG_DIR"
  ensure_filters_file || true
  require_editor
  "$EDITOR_BIN" "$FILTERS_FILE"
}

# apaga diretórios de execução (dry-run e prod) com mais de N dias
cmd_log_delete() {
  local days="${1:-30}"
  case "$days" in
    ''|*[!0-9]*)
      err_box "Valor inválido para --log-delete: '$days' (deve ser um número inteiro de dias)."
      exit 1
      ;;
  esac

  local dirs=("$LOGS_DIR/dry-run" "$LOGS_DIR/prod") d target
  local total_deleted=0

  box_top "dolly · log-delete"
  box_line "Removendo execuções com mais de $days dia(s) em $LOGS_DIR"
  box_bottom

  for d in "${dirs[@]}"; do
    [ -d "$d" ] || continue
    while IFS= read -r -d '' target; do
      info "removendo $target"
      rm -rf -- "$target"
      total_deleted=$((total_deleted + 1))
    done < <(find "$d" -mindepth 1 -maxdepth 1 -type d -mtime "+$days" -print0)
  done

  if [ "$total_deleted" -eq 0 ]; then
    ok "Nenhuma execução com mais de $days dia(s) encontrada."
  else
    ok "$total_deleted execução(ões) removida(s)."
  fi
}

# lista os diretórios de execução (timestamps) de um modo (dry-run ou prod),
# em ordem decrescente (mais recente primeiro); os nomes no formato
# %Y%m%d-%H%M%S ordenam igual cronologicamente
list_run_dirs_desc() {
  local mode_dir="$1" d
  for d in "$mode_dir"/*/; do
    [ -d "$d" ] || continue
    printf '%s\n' "${d%/}"
  done | sort -r
}

# mostra até $dir_count diretórios de execução mais recentes do modo escolhido
# e pede ao usuário para escolher um; devolve o caminho do diretório escolhido
choose_run_dir() {
  local mode_dir="$1" dir_count="$2"
  local dirs=() d
  while IFS= read -r d; do dirs+=("$d"); done \
    < <(list_run_dirs_desc "$mode_dir")

  if [ "${#dirs[@]}" -eq 0 ]; then
    err_box "Nenhuma execução encontrada em $mode_dir." "Rode 'dolly --dry-run' ou 'dolly -y' primeiro."
    exit 1
  fi

  local shown=("${dirs[@]:0:dir_count}")

  if [ "${#shown[@]}" -eq 1 ]; then
    printf '%s' "${shown[0]}"
    return
  fi

  {
    box_top "dolly · view-log"
    box_line "Execuções mais recentes em $mode_dir"
    box_line ""
    local i
    for i in "${!shown[@]}"; do
      box_line "$(printf '%2d) %s' "$((i + 1))" "$(basename "${shown[$i]}")")"
    done
    box_bottom
  } >&2

  local reply idx
  printf 'Escolha o diretório [1-%d] (padrão: 1): ' "${#shown[@]}" >&2
  read -r reply
  reply="${reply:-1}"
  case "$reply" in
    ''|*[!0-9]*)
      err_box "Escolha inválida: '$reply'."
      exit 1
      ;;
  esac
  idx=$((reply - 1))
  if [ "$idx" -lt 0 ] || [ "$idx" -ge "${#shown[@]}" ]; then
    err_box "Escolha fora do intervalo: '$reply'."
    exit 1
  fi
  printf '%s' "${shown[$idx]}"
}

# pergunta ao usuário se quer ver as execuções de dry-run ou de prod;
# devolve o caminho do diretório do modo escolhido
choose_log_mode() {
  {
    box_top "dolly · view-log"
    box_line "Qual modo deseja ver?"
    box_line ""
    box_line " 1) dry-run"
    box_line " 2) prod"
    box_bottom
  } >&2

  local reply
  printf 'Escolha [1-2] (padrão: 1): ' >&2
  read -r reply
  reply="${reply:-1}"
  case "$reply" in
    1) printf '%s' "$LOGS_DIR/dry-run" ;;
    2) printf '%s' "$LOGS_DIR/prod" ;;
    *)
      err_box "Escolha inválida: '$reply'."
      exit 1
      ;;
  esac
}

# mostra um dos arquivos de log (*.rclone.log, *.changes.log, summary.log) de
# uma execução escolhida pelo usuário dentro do modo selecionado (dry-run ou
# prod); por padrão lista os 5 diretórios de execução mais recentes (ordem
# decrescente), quantidade ajustável via --dir N
cmd_view_log() {
  local dir_count=5
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dir)
        shift
        if ! [[ "${1:-}" =~ ^-?[0-9]+$ ]]; then
          err_box "Valor inválido para --dir: '${1:-}' (deve ser um número inteiro)."
          exit 1
        fi
        dir_count="$1"
        shift
        ;;
      *)
        err_box "Opção desconhecida para --view-log: '$1'."
        exit 1
        ;;
    esac
  done
  if [ "$dir_count" -le 0 ]; then
    dir_count=5
  fi

  require_pager

  local mode_dir
  mode_dir="$(choose_log_mode)"

  local run_dir
  run_dir="$(choose_run_dir "$mode_dir" "$dir_count")"

  local logs=() f
  while IFS= read -r -d '' f; do logs+=("$f"); done \
    < <(find "$run_dir" -maxdepth 1 -type f -name '*.log' -print0 | sort -z)

  if [ "${#logs[@]}" -eq 0 ]; then
    err_box "Nenhum arquivo de log encontrado em $run_dir."
    exit 1
  fi

  local chosen
  if [ "${#logs[@]}" -eq 1 ]; then
    chosen="${logs[0]}"
  else
    box_top "dolly · view-log"
    box_line "Execução: $run_dir"
    box_line ""
    local i
    for i in "${!logs[@]}"; do
      box_line "$(printf '%2d) %s' "$((i + 1))" "$(basename "${logs[$i]}")")"
    done
    box_bottom

    local reply idx
    printf 'Escolha o arquivo [1-%d] (padrão: 1): ' "${#logs[@]}"
    read -r reply
    reply="${reply:-1}"
    case "$reply" in
      ''|*[!0-9]*)
        err_box "Escolha inválida: '$reply'."
        exit 1
        ;;
    esac
    idx=$((reply - 1))
    if [ "$idx" -lt 0 ] || [ "$idx" -ge "${#logs[@]}" ]; then
      err_box "Escolha fora do intervalo: '$reply'."
      exit 1
    fi
    chosen="${logs[$idx]}"
  fi

  local lang_args=()
  if [ "$PAGER_BIN" = "bat" ]; then
    case "$chosen" in
      *.changes.log) lang_args=(--language=diff) ;;
    esac
  fi

  "$PAGER_BIN" "${PAGER_ARGS[@]}" "${lang_args[@]}" "$chosen"
}

# expande $VAR, ${VAR} e ~ (home) num caminho lido do paths.conf
expand_path() {
  local input="$1" result="" rest name value match

  case "$input" in
    "~") input="$HOME" ;;
    "~/"*) input="$HOME/${input#\~/}" ;;
  esac

  rest="$input"
  while [[ "$rest" =~ \$\{([A-Za-z_][A-Za-z0-9_]*)\}|\$([A-Za-z_][A-Za-z0-9_]*) ]]; do
    match="${BASH_REMATCH[0]}"
    name="${BASH_REMATCH[1]:-${BASH_REMATCH[2]}}"
    value="${!name-}"
    result+="${rest%%"$match"*}$value"
    rest="${rest#*"$match"}"
  done
  result+="$rest"

  printf '%s' "$result"
}

# Preenche o array global JOBS com entradas "job|source|destination"
load_paths() {
  JOBS=()
  if [ ! -f "$PATHS_FILE" ]; then
    err_box "Arquivo de configuração não encontrado: $PATHS_FILE" "Rode '${SCRIPT_NAME} init' primeiro."
    exit 1
  fi

  local line raw_src raw_dst src dst job
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    [ -z "$line" ] && continue
    case "$line" in \#*) continue ;; esac

    raw_src="${line%%|*}"
    raw_dst="${line#*|}"
    if [ "$raw_src" = "$line" ] || [ -z "$raw_dst" ]; then
      warn "Linha inválida em $PATHS_FILE, ignorando: $line"
      continue
    fi
    src="$(expand_path "$raw_src")"
    dst="$(expand_path "$raw_dst")"
    if [ ! -d "$src" ]; then
      warn "Diretório de origem não existe, ignorando job: $src"
      continue
    fi
    job="$(basename -- "$dst")"
    JOBS+=("$job|$src|$dst")
  done < "$PATHS_FILE"

  if [ "${#JOBS[@]}" -eq 0 ]; then
    err_box "Nenhum par válido em $PATHS_FILE."
    exit 1
  fi
}

run_sync() {
  local is_dry_run="$1"; shift
  local is_mirror="$1"; shift
  local extra_rclone_args=("$@")
  require_rclone
  load_paths

  local mode_dir="prod"
  [ "$is_dry_run" = "1" ] && mode_dir="dry-run"

  local timestamp run_dir
  timestamp="$(date +%Y%m%d-%H%M%S)"
  run_dir="$LOGS_DIR/$mode_dir/$timestamp"
  mkdir -p "$run_dir"

  local filter_args=()
  [ -f "$FILTERS_FILE" ] && filter_args=(--filter-from "$FILTERS_FILE")

  local total_add=0 total_mod=0 total_del=0 any_failed=0
  local mirror_label="não"
  [ "$is_mirror" = "1" ] && mirror_label="sim"
  local summary_file="$run_dir/summary.log"
  {
    echo "dolly run - $timestamp - modo: $mode_dir - mirror: $mirror_label"
    echo
  } > "$summary_file"

  local mode_label="execução real"
  [ "$is_dry_run" = "1" ] && mode_label="dry-run"

  box_top "dolly · $mode_label"
  box_line "Logs desta execução: $run_dir"
  [ "${#extra_rclone_args[@]}" -gt 0 ] && box_line "Flags extras: ${extra_rclone_args[*]}"
  [ "$is_mirror" = "1" ] && box_line "⚠ modo --mirror: arquivos removidos na origem serão apagados no destino" \
    "$(printf '%s⚠ modo --mirror: arquivos removidos na origem serão apagados no destino%s' "$C_YELLOW" "$C_RESET")"
  box_bottom

  local entry job rest src dst rlog clog combined_raw rc_args status added modified removed cline
  local stats_bytes stats_elapsed stats_checks stats_files
  for entry in "${JOBS[@]}"; do
    job="${entry%%|*}"
    rest="${entry#*|}"
    src="${rest%%|*}"
    dst="${rest#*|}"

    rlog="$run_dir/$job.rclone.log"
    clog="$run_dir/$job.changes.log"

    box_top "→ $job"
    box_line "→ origem   $src"  "$(printf '%s%s→%s origem   %s%s%s' "$C_GREEN" "$C_BOLD" "$C_RESET" "$C_DIM" "$src" "$C_RESET")"
    box_line "← destino  $dst"  "$(printf '%s%s←%s destino  %s%s%s' "$C_BLUE" "$C_BOLD" "$C_RESET" "$C_DIM" "$dst" "$C_RESET")"

    mkdir -p "$dst"

    local rclone_subcmd="copy"
    [ "$is_mirror" = "1" ] && rclone_subcmd="sync"

    combined_raw="$run_dir/.$job.combined.raw"
    rc_args=("$rclone_subcmd" "$src" "$dst" "${filter_args[@]}" --create-empty-src-dirs -v \
      --log-file "$rlog" --combined "$combined_raw")
    [ "$is_dry_run" = "1" ] && rc_args+=(--dry-run)
    [ "${#extra_rclone_args[@]}" -gt 0 ] && rc_args+=("${extra_rclone_args[@]}")

    status=0
    rclone "${rc_args[@]}" || status=$?

    # --combined lista TODOS os arquivos, incluindo "= " (inalterados);
    # mantemos em changes.log só o que de fato mudou (estilo git status).
    # Fora do modo --mirror usamos "rclone copy", que nunca apaga nada; o
    # relatório ainda marca arquivos só-no-destino com "- ", mas como o
    # rclone escolheu não tocá-los isso não é uma mudança real, então
    # tratamos "- " como "= " (ignorado) a menos que --mirror esteja ativo.
    local combined_pattern='^[+*] '
    [ "$is_mirror" = "1" ] && combined_pattern='^[+*-] '
    grep -E "$combined_pattern" "$combined_raw" > "$clog" 2>/dev/null || true
    rm -f "$combined_raw"

    added="$(grep -c '^+ ' "$clog" 2>/dev/null || true)"
    modified="$(grep -c '^\* ' "$clog" 2>/dev/null || true)"
    removed="$(grep -c '^- ' "$clog" 2>/dev/null || true)"
    added=${added:-0}; modified=${modified:-0}; removed=${removed:-0}

    box_line ""

    if [ "$status" -ne 0 ]; then
      box_line "✖ falhou (rclone exit $status) — veja $rlog" \
        "$(printf '%s✖ falhou (rclone exit %s)%s — veja %s' "$C_RED" "$status" "$C_RESET" "$rlog")"
      any_failed=1
    else
      box_line "✔ concluído   +$added adicionados   ~$modified modificados   -$removed removidos" \
        "$(printf '%s✔ concluído%s   %s+%s%s adicionados   %s~%s%s modificados   %s-%s%s removidos' \
          "$C_GREEN" "$C_RESET" "$C_GREEN" "$added" "$C_RESET" "$C_YELLOW" "$modified" "$C_RESET" "$C_RED" "$removed" "$C_RESET")"
    fi

    box_line ""

    # rclone grava "Transferred:"/"Elapsed time:" com espaçamento inconsistente
    # (tab numa linha, espaços na outra); realinhamos nós mesmos ao exibir.
    stats_bytes="$(grep -E '^Transferred:.*ETA' "$rlog" 2>/dev/null | tail -1 | sed -E 's/^Transferred:[[:space:]]*//' || true)"
    stats_elapsed="$(grep -E '^Elapsed time:' "$rlog" 2>/dev/null | tail -1 | sed -E 's/^Elapsed time:[[:space:]]*//' || true)"
    stats_checks="$(grep -E '^Checks:' "$rlog" 2>/dev/null | tail -1 | sed -E 's/^Checks:[[:space:]]*//; s/Listed/Listados/' || true)"
    stats_files="$(grep -E '^Transferred:' "$rlog" 2>/dev/null | grep -v 'ETA' | tail -1 | sed -E 's/^Transferred:[[:space:]]*//' || true)"
    [ -n "$stats_bytes" ]   && box_line "$(printf '%-12s %s' "transferido" "$stats_bytes")"
    [ -n "$stats_elapsed" ] && box_line "$(printf '%-12s %s' "tempo" "$stats_elapsed")"
    [ -n "$stats_checks" ]  && box_line "$(printf '%-12s %s' "verificações" "$stats_checks")"
    [ -n "$stats_files" ]   && box_line "$(printf '%-12s %s' "arquivos" "$stats_files")"

    if [ -s "$clog" ]; then
      box_divider
      local total_lines
      total_lines="$(wc -l < "$clog" | tr -d ' ')"
      while IFS= read -r cline; do
        case "$cline" in
          '+ '*) box_line "$cline" "$(printf '%s%s%s' "$C_GREEN" "$cline" "$C_RESET")" ;;
          '* '*) box_line "$cline" "$(printf '%s%s%s' "$C_YELLOW" "$cline" "$C_RESET")" ;;
          '- '*) box_line "$cline" "$(printf '%s%s%s' "$C_RED" "$cline" "$C_RESET")" ;;
          *) box_line "$cline" ;;
        esac
      done < <(head -n "$MAX_CHANGE_LINES" "$clog")
      if [ "$total_lines" -gt "$MAX_CHANGE_LINES" ]; then
        box_line "$(printf '… e mais %d alterações' "$((total_lines - MAX_CHANGE_LINES))")"
      fi
      box_line "$(printf '→ ver %s' "$clog")" "$(printf '%s→ ver %s%s' "$C_DIM" "$clog" "$C_RESET")"
    fi
    box_bottom

    {
      echo "## $job"
      echo "source: $src"
      echo "destination: $dst"
      echo "adicionados: $added  modificados: $modified  removidos: $removed"
      echo
      cat "$clog" 2>/dev/null
      echo
    } >> "$summary_file"

    total_add=$((total_add + added))
    total_mod=$((total_mod + modified))
    total_del=$((total_del + removed))
  done

  local grand_total=$((total_add + total_mod + total_del))
  local value_width=${#grand_total}
  [ "$value_width" -lt 1 ] && value_width=1
  box_top "Resumo"
  box_line "$(printf '%s pares processados · %s alterações' "${#JOBS[@]}" "$grand_total")"
  box_line ""
  meter_bar "adicionados" "$total_add" "$grand_total" "$C_GREEN"  "$value_width"
  meter_bar "modificados" "$total_mod" "$grand_total" "$C_YELLOW" "$value_width"
  meter_bar "removidos"   "$total_del" "$grand_total" "$C_RED"    "$value_width"
  box_line ""
  box_line "Logs completos em: $run_dir"
  box_bottom

  {
    echo "## Totais"
    echo "adicionados: $total_add  modificados: $total_mod  removidos: $total_del"
  } >> "$summary_file"

  if [ "$any_failed" -ne 0 ]; then
    err_box "Um ou mais jobs falharam."
    exit 1
  fi
}

confirm_prod() {
  local is_mirror="$1" msg
  if [ "$is_mirror" = "1" ]; then
    msg="Isso vai sincronizar de verdade e apagar no destino os arquivos que não existirem mais na origem."
  else
    msg="Isso vai sincronizar de verdade (nada será apagado no destino; use --mirror para espelhar remoções)."
  fi
  box_top "confirmação" "$C_YELLOW"
  box_line "⚠ $msg" "$(printf '%s⚠%s %s' "$C_YELLOW" "$C_RESET" "$msg")" "$C_YELLOW"
  box_bottom "$C_YELLOW"
  printf 'Continuar? [y/N] '
  local reply
  read -r reply
  case "$reply" in
    [yY]|[yY][eE][sS]) return 0 ;;
    *) info "Cancelado."; exit 0 ;;
  esac
}

main() {
  case "${1:-}" in
    init)
      cmd_init
      return
      ;;
    -h|--help|help)
      usage
      return
      ;;
    --edit-path|-ep)
      cmd_edit_path
      return
      ;;
    --edit-filter|-ef)
      cmd_edit_filter
      return
      ;;
    --log-delete|-lgd)
      shift
      cmd_log_delete "$@"
      return
      ;;
    --view-log|-vl)
      shift
      cmd_view_log "$@"
      return
      ;;
  esac

  # flags próprias do dolly são consumidas aqui; qualquer outro argumento é
  # repassado como flag nativa do rclone (ex.: --bwlimit 1M, --transfers 8).
  local is_dry_run=0 auto_yes=0 is_mirror=0
  local extra_rclone_args=() arg
  for arg in "$@"; do
    case "$arg" in
      -d|--dry-run) is_dry_run=1 ;;
      -y|--yes) auto_yes=1 ;;
      -m|--mirror) is_mirror=1 ;;
      *) extra_rclone_args+=("$arg") ;;
    esac
  done

  if [ "$is_dry_run" -eq 0 ] && [ "$auto_yes" -eq 0 ]; then
    confirm_prod "$is_mirror"
  fi
  run_sync "$is_dry_run" "$is_mirror" "${extra_rclone_args[@]}"
}

main "$@"
